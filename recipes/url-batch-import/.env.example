# URL Batch Import — Environment Variables
#
# Copy this file to .env, fill in your values, then run:
#   source .env
# before running import-urls.ts

# Supabase direct insert (default)
export SUPABASE_URL=https://YOUR_REF.supabase.co
export SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
export OPENROUTER_API_KEY=sk-or-v1-your-key

# Optional: Custom edge function endpoint
# (enable with --ingest-endpoint flag)
# export INGEST_URL=https://YOUR_REF.supabase.co/functions/v1/ingest-thought
# export INGEST_KEY=your-ingest-key
